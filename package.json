{
  "name": "pickai",
  "version": "2.1.0",
  "description": "Filter, score, and recommend AI models across providers. Metadata-first, powered by models.dev. Zero deps.",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build",
    "docs:dev": "pnpm --filter pickai-docs dev",
    "docs:build": "pnpm --filter pickai-docs build",
    "docs:preview": "pnpm --filter pickai-docs preview"
  },
  "keywords": [
    "ai",
    "models",
    "llm",
    "model-selection",
    "scoring",
    "classification",
    "anthropic",
    "openai",
    "google",
    "openrouter"
  ],
  "author": "Mark Lozano",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/niftymonkey/pickai"
  },
  "homepage": "https://pickai.niftymonkey.dev",
  "bugs": {
    "url": "https://github.com/niftymonkey/pickai/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.26.2",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
